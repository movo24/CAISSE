# ══════════════════════════════════════════════════════
# POS CAISSE — Production Environment
# ══════════════════════════════════════════════════════

# ── Runtime ──────────────────────────────────────────
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/caisse
# TYPEORM_SYNCHRONIZE is FORBIDDEN in production (enforced at runtime)

# ── Redis (token revocation, rate limit, cache) ─────
REDIS_URL=redis://host:6379

# ── Authentication ───────────────────────────────────
# Generate with: openssl rand -hex 32
# MUST be ≥ 32 chars, MUST NOT be default values
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── CORS ─────────────────────────────────────────────
# Production domains only — NO localhost, NO wildcard
CORS_ORIGIN=https://pos.yourdomain.com

# ── TimeWin24 Integration ───────────────────────────
TIMEWIN24_URL=https://timewin.yourdomain.com
TIMEWIN24_API_KEY=tw24_xxx
TIMEWIN24_POS_SECRET=xxx
# Key ID for HMAC authentication (ConnectedApp or PosProvider ID in TimeWin24)
TIMEWIN24_POS_KEY_ID=

# Timeout and circuit breaker (defaults shown)
TIMEWIN24_TIMEOUT_MS=5000
TIMEWIN24_RETRY_COUNT=3
TIMEWIN24_RETRY_DELAY_MS=30000

# ── Rate Limiting (defaults shown, override if needed) ──
# RATE_LIMIT_SHORT_TTL=1000
# RATE_LIMIT_SHORT_MAX=50
# RATE_LIMIT_MEDIUM_TTL=60000
# RATE_LIMIT_MEDIUM_MAX=1000
# RATE_LIMIT_LONG_TTL=3600000
# RATE_LIMIT_LONG_MAX=30000

# ── Monitoring ───────────────────────────────────────
SENTRY_DSN=
# Log level: error, warn, info (default), debug, verbose
LOG_LEVEL=info
# Alerting webhook (Slack, Discord, or custom — optional)
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx

# ── Payments ─────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
