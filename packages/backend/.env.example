# ─────────────────────────────────────────────────────────────────
# CAISSE Backend — Environment Variables
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env (NEVER commit .env).
# In production (Railway / Render / Fly), set these via the platform's
# variable UI — do NOT ship a .env file in the Docker image.
# ─────────────────────────────────────────────────────────────────

# ── REQUIRED — app refuses to start without these ─────────────────
NODE_ENV=development
DATABASE_URL=postgresql://caisse:caisse@localhost:5432/caisse
# Generate each with: openssl rand -hex 32  (must be ≥32 chars, must NOT use insecure defaults)
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Server ────────────────────────────────────────────────────────
PORT=3001
# Comma-separated list. In prod, restrict to actual frontend domains.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5177
# error | warn | info | debug | verbose
LOG_LEVEL=info

# ── TypeORM ───────────────────────────────────────────────────────
# FORBIDDEN in production. Migrations only. The app will crash at boot
# if NODE_ENV=production && TYPEORM_SYNCHRONIZE=true.
# TYPEORM_SYNCHRONIZE=true

# ── Cache / Rate-limit (optional but recommended in prod) ─────────
# Without REDIS_URL the app falls back to in-memory cache (NOT multi-instance safe).
# REDIS_URL=redis://default:password@host:6379

# Rate limit tiers (defaults shown). Per-IP.
# RATE_LIMIT_SHORT_TTL=1000
# RATE_LIMIT_SHORT_MAX=50
# RATE_LIMIT_MEDIUM_TTL=60000
# RATE_LIMIT_MEDIUM_MAX=1000
# RATE_LIMIT_LONG_TTL=3600000
# RATE_LIMIT_LONG_MAX=30000

# ── Monitoring (optional but strongly recommended in prod) ────────
# SENTRY_DSN=https://your-sentry-dsn
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Stripe (payments) ─────────────────────────────────────────────
# Disable Stripe by leaving these unset; payment endpoints will refuse.
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# ── TimeWin24 Integration (optional) ──────────────────────────────
# If unset, integration is disabled (logged as warning at boot).
TIMEWIN24_URL=http://localhost:3000
TIMEWIN24_API_KEY=tw24_YOUR_API_KEY

# ── External APIs (optional) ──────────────────────────────────────
PRIM_API_KEY=YOUR_PRIM_API_KEY
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
RADAR_API_KEY=YOUR_RADAR_SHARED_SECRET
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY

# ── Airtable Ops Layer (optional — visual ops cockpit) ───────────
# Set AIRTABLE_ENABLED=true to activate. All other vars are required when enabled.
# PostgreSQL remains the source of truth — Airtable is read/write ops dashboard only.
# NEVER commit a real API key. Generate webhook secret with: openssl rand -hex 32
AIRTABLE_ENABLED=false
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_PRODUCTS_TABLE_ID=
AIRTABLE_STORES_TABLE_ID=
AIRTABLE_SUPPLIERS_TABLE_ID=
AIRTABLE_STOCK_TABLE_ID=
AIRTABLE_OPERATIONS_TABLE_ID=
AIRTABLE_WEBHOOK_SECRET=
# Cron expression for scheduled sync (default: every 30 min)
AIRTABLE_SYNC_CRON=*/30 * * * *
# Max Airtable API calls per second (Airtable limit is 5/sec; use 4 for safety)
AIRTABLE_RATE_LIMIT_PER_SECOND=4

# ── Sales Guards (anti-error engine) ─────────────────────────────
# Read-only engine that flags cart anomalies before payment. Thresholds only —
# the engine never modifies sales/tickets. Set ENABLED=false to disable entirely.
SALES_GUARDS_ENABLED=true
# Gross-margin % below which a "low margin" warning is raised
SALES_GUARDS_LOW_MARGIN_PCT=20
# Line discount % above which manager approval is required
SALES_GUARDS_EXCESSIVE_DISCOUNT_PCT=20
# Manual-price deviation % vs catalogue → warning
SALES_GUARDS_MANUAL_PRICE_WARN_PCT=5
# Manual-price deviation % vs catalogue → blocking + manager approval
SALES_GUARDS_MANUAL_PRICE_BLOCK_PCT=20
# Free-product daily count above which an alert is raised
SALES_GUARDS_FREE_PRODUCT_DAILY_THRESHOLD=10
# Cancellation count above which a backoffice alert is raised
SALES_GUARDS_CANCELLATION_THRESHOLD=5
