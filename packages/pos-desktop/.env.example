# ─────────────────────────────────────────────────────────────────
# POS Caisse — desktop / web env template
# Copy to .env and fill YOUR values. NEVER commit a real .env.
# All values below are FICTIONAL placeholders.
# ─────────────────────────────────────────────────────────────────

# API base URL the app talks to.
#   - Leave EMPTY in local dev → Vite proxies /api → http://localhost:3001
#   - Desktop / Capacitor builds fall back to the production API if empty
#     (see src/renderer/utils/apiConfig.ts)
#
# Per environment, set one of:
#   dev      → (leave empty, uses local proxy)
#   staging  → https://staging-api.example.com
#   prod     → https://api.example.com
VITE_API_URL=

# Optional: app version stamped into the desktop build (else taken from package.json)
# POS_APP_VERSION=0.1.0
