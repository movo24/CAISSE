# ── Production Environment Variables ────────────────────────────
# Copy to .env.production and fill in real values
# docker compose -f docker/docker-compose.prod.yml --env-file docker/.env.production up -d
# ─────────────────────────────────────────────────────────────────

# Database
DB_USER=caisse
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_NAME=caisse

# JWT (generate: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

# AI Services
ANTHROPIC_API_KEY=sk-ant-api03-xxx
GEMINI_API_KEY=AIzaSyXxx
POS_AI_ENABLED=true

# External APIs (get your own keys — never commit real values)
PRIM_API_KEY=YOUR_PRIM_API_KEY_HERE
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE
