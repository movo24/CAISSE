{
  "name": "caisse",
  "version": "0.1.0",
  "private": true,
  "description": "Modern POS system - SaaS multi-store, multi-currency, AI-powered",
  "workspaces": [
    "packages/*",
    "shared"
  ],
  "scripts": {
    "dev:backend": "cd packages/backend && npm run start:dev",
    "dev:pos": "cd packages/pos-desktop && npm run dev",
    "dev:backoffice": "cd packages/backoffice-web && npm run dev",
    "build:backend": "cd packages/backend && npm run build",
    "build:pos": "cd packages/pos-desktop && npm run build",
    "build:backoffice": "cd packages/backoffice-web && npm run build",
    "test": "npm run test --workspaces",
    "test:backend": "cd packages/backend && npm test",
    "test:backoffice": "cd packages/backoffice-web && npm test",
    "test:pos": "cd packages/pos-desktop && npm test",
    "test:mobile": "cd packages/mobile && npm test",
    "test:control": "cd packages/wesley-control && npm test",
    "test:front": "npm run test:backoffice && npm run test:pos && npm run test:mobile && npm run test:control",
    "dev:control": "cd packages/wesley-control && npm start",
    "typecheck:control": "cd packages/wesley-control && npm run typecheck",
    "test:e2e:list": "cd packages/pos-desktop && npx playwright test --list",
    "preflight": "bash scripts/preflight.sh",
    "preflight:full": "bash scripts/preflight.sh --full",
    "test:security": "cd packages/backend && npx jest src/common/config test/env-example-completeness.spec.ts test/env-example-no-secrets.spec.ts test/docs-no-secrets.spec.ts test/source-no-secrets.spec.ts test/gitignore-hardening.spec.ts test/ci-scripts-exist.spec.ts",
    "lint": "npm run lint --workspaces",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "api:map": "node scripts/generate-api-map.js"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.23",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "jsbarcode": "^3.12.3",
    "nodemailer": "^6.10.1"
  }
}
